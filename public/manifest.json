{
  "manifest_version": 3,
  "name": "Grab",
  "version": "1.2.0",
  "description": "Trova immagini in tempo reale, filtra, scarica singoli file o crea ZIP con metadata JSON.",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "downloads",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Apri Grab",
    "default_icon": {
      "16": "icons/icon-dark-16.png",
      "32": "icons/icon-dark-32.png",
      "48": "icons/icon-dark-48.png",
      "128": "icons/icon-dark-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-dark-16.png",
    "32": "icons/icon-dark-32.png",
    "48": "icons/icon-dark-48.png",
    "128": "icons/icon-dark-128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}